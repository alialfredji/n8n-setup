# n8n Configuration
N8N_ENCRYPTION_KEY=generate_with_openssl_rand_hex_32
N8N_USER_MANAGEMENT_JWT_SECRET=generate_with_openssl_rand_hex_32
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_to_secure_password

# PostgreSQL Configuration
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=change_me_to_secure_password

# Domain Configuration
DOMAIN=n8n.yourdomain.com

# LinkedIn Analytics Configuration
LINKEDIN_USERNAME=your@email.com
LINKEDIN_PASSWORD=yourpassword
CRON_SCHEDULE=0 6 * * *
